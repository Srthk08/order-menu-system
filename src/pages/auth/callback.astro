---
import Layout from '../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

// Supabase configuration
const SUPABASE_URL = 'https://lmrrdcaavwwletcjcpqv.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxtcnJkY2Fhdnd3bGV0Y2pjcHF2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTU1MDQ0ODgsImV4cCI6MjA3MTA4MDQ4OH0.AU59Qfr6K9i880Gcn5y-3pjCf8PXsDIq4OI0-lPQVuQ';

const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

// Handle the OAuth callback
let authResult = null;
let error = null;

try {
  const { data, error: authError } = await supabase.auth.getSession();
  
  if (authError) {
    error = authError.message;
  } else if (data.session) {
    authResult = data.session;
  }
} catch (err) {
  error = err.message;
}
---

<Layout title="Authentication Callback">
  <!-- IMMEDIATE REDIRECT CHECK - Runs before any other scripts -->
  <script is:inline>
    (function() {
      'use strict';
      try {
        const hostname = window.location.hostname;
        const origin = window.location.origin;
        const pathname = window.location.pathname;
        
        // Check if we're on a 24hour project
        const is24HourProject = hostname.includes('24hour') || 
                               hostname.includes('24-hour') || 
                               origin.includes('24hour') ||
                               pathname.includes('24hour');
        
        // Get stored origin from sessionStorage or localStorage
        const storedOrigin = (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('oauth-origin')) ||
                            (typeof localStorage !== 'undefined' && localStorage.getItem('oauth-origin'));
        
        console.log('🚨 IMMEDIATE CHECK (inline script):', {
          hostname: hostname,
          origin: origin,
          is24HourProject: is24HourProject,
          storedOrigin: storedOrigin,
          shouldRedirect: is24HourProject || (storedOrigin && storedOrigin !== origin)
        });
        
        // If we're on the wrong project, redirect immediately
        if (is24HourProject) {
          console.error('❌ WRONG PROJECT DETECTED (24hour)! Redirecting immediately...');
          const correctOrigin = storedOrigin || 'http://localhost:4321';
          const redirectPath = (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('oauth-path')) || '/signup';
          const currentSearch = window.location.search;
          const currentHash = window.location.hash;
          const redirectUrl = `${correctOrigin}/auth/callback${currentSearch}${currentHash}`;
          console.log('🔄 Redirecting to:', redirectUrl);
          window.location.replace(redirectUrl);
          return;
        }
        
        // If origin doesn't match stored origin, redirect
        if (storedOrigin && storedOrigin !== origin) {
          console.warn('⚠️ ORIGIN MISMATCH! Redirecting to stored origin...');
          const redirectPath = (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('oauth-path')) || '/signup';
          const currentSearch = window.location.search;
          const currentHash = window.location.hash;
          const redirectUrl = `${storedOrigin}/auth/callback${currentSearch}${currentHash}`;
          console.log('🔄 Redirecting to:', redirectUrl);
          window.location.replace(redirectUrl);
          return;
        }
      } catch (e) {
        console.error('Error in immediate redirect check:', e);
      }
    })();
  </script>
  
  <main class="min-h-screen flex items-center justify-center bg-white">
    <div class="max-w-md w-full space-y-8">
      <div class="text-center">
        <h2 class="mt-6 text-3xl font-extrabold text-gray-900">
          {error ? 'Authentication Error' : 'Processing Authentication...'}
        </h2>
        <p class="mt-2 text-sm text-gray-700">
          {error ? 'There was an error with your authentication.' : 'Please wait while we complete your sign-in.'}
        </p>
      </div>

      <div class="mt-8 space-y-6">
        {error ? (
          <div class="bg-red-50 border border-red-200 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">Authentication Failed</h3>
                <div class="mt-2 text-sm text-red-700">
                  <p>{error}</p>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <div class="bg-white border border-gray-200 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="animate-spin h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-gray-800">Processing...</h3>
                <div class="mt-2 text-sm text-gray-700">
                  <p>Setting up your account and redirecting...</p>
                </div>
              </div>
            </div>
          </div>
        )}

        <div class="flex space-x-4">
          <a href="/login" class="flex-1 bg-gray-800 text-white text-center py-2 px-4 rounded-md hover:bg-gray-900 transition duration-150 ease-in-out">
            Back to Login
          </a>
          <a href="/" class="flex-1 bg-gray-600 text-white text-center py-2 px-4 rounded-md hover:bg-gray-700 transition duration-150 ease-in-out">
            Go Home
          </a>
        </div>
      </div>
    </div>
  </main>
  <style>
    /* Ensure white background on this page regardless of parent styles */
    main { background-color: #fff !important; }
    body { background-color: #fff !important; }
  </style>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL = 'https://lmrrdcaavwwletcjcpqv.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxtcnJkY2Fhdnd3bGV0Y2pjcHF2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTU1MDQ0ODgsImV4cCI6MjA3MTA4MDQ4OH0.AU59Qfr6K9i880Gcn5y-3pjCf8PXsDIq4OI0-lPQVuQ';
  
  // Use the same Supabase client configuration as the rest of the app
  // This ensures PKCE state is preserved
  let supabase;
  
  // First, try to use the global Supabase client from Layout.astro (if available)
  if (typeof window !== 'undefined' && window.supabase && window.supabase.auth) {
    console.log('✅ Using global Supabase client');
    supabase = window.supabase;
  } else {
    // Create a new client with the same config
    console.log('⚠️ Creating new Supabase client (global not available)');
    supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      auth: {
        autoRefreshToken: true,
        persistSession: true,
        detectSessionInUrl: true,
        flowType: 'pkce',
        storage: window.localStorage, // Ensure we use localStorage for PKCE state
        storageKey: 'sb-auth-token' // Standard Supabase storage key
      }
    });
  }

  // Check Supabase connectivity first
  (async function checkSupabaseConnection() {
    try {
      console.log('🔍 Checking Supabase connectivity...');
      const testResponse = await fetch(`${SUPABASE_URL}/rest/v1/`, {
        method: 'HEAD',
        headers: { 'apikey': SUPABASE_ANON_KEY },
        signal: AbortSignal.timeout(3000) // 3 second timeout
      });
      console.log('✅ Supabase is reachable');
    } catch (err) {
      console.error('❌ Supabase connection failed:', err);
      // Don't block, but log the error
      if (err.name === 'TimeoutError' || err.message?.includes('Failed to fetch') || err.message?.includes('ERR_NAME_NOT_RESOLVED')) {
        console.error('⚠️ Supabase URL may be incorrect or unreachable:', SUPABASE_URL);
        // Show error to user after a delay
        setTimeout(() => {
          const errorMsg = 'Cannot connect to authentication server. Please check your internet connection.';
          window.location.href = `/login?error=${encodeURIComponent(errorMsg)}`;
        }, 2000);
      }
    }
  })();

  // IMMEDIATE CHECK: Detect if we're on the wrong project and redirect
  (function() {
    const storedOrigin = sessionStorage.getItem('oauth-origin') || localStorage.getItem('oauth-origin');
    const currentOrigin = window.location.origin;
    const hostname = window.location.hostname;
    const pathname = window.location.pathname;
    
    // Check if we're on a 24hour project URL
    const is24HourProject = hostname.includes('24hour') || 
                           hostname.includes('24-hour') || 
                           pathname.includes('24hour') ||
                           currentOrigin.includes('24hour');
    
    // Check if we have a stored origin that's different
    const originMismatch = storedOrigin && storedOrigin !== currentOrigin;
    
    console.log('🚨 IMMEDIATE CHECK - Callback validation:', {
      storedOrigin: storedOrigin,
      currentOrigin: currentOrigin,
      hostname: hostname,
      is24HourProject: is24HourProject,
      originMismatch: originMismatch,
      shouldRedirect: is24HourProject || originMismatch
    });
    
    // If we're on the wrong project, redirect immediately
    if (is24HourProject || (originMismatch && storedOrigin)) {
      console.error('❌ WRONG PROJECT DETECTED! Redirecting immediately...');
      const correctOrigin = storedOrigin || 'http://localhost:4321';
      const redirectPath = sessionStorage.getItem('oauth-path') || '/signup';
      // Preserve the OAuth code/tokens in the URL if present
      const currentSearch = window.location.search;
      const currentHash = window.location.hash;
      const redirectUrl = `${correctOrigin}/auth/callback${currentSearch}${currentHash}`;
      console.log('🔄 Redirecting to:', redirectUrl);
      window.location.replace(redirectUrl);
      return; // Stop execution
    }
  })();

  // Handle the OAuth callback
  async function handleAuthCallback() {
    console.log('🚀 Starting OAuth callback handler...');
    console.log('📍 Current URL:', window.location.href);
    console.log('📍 Has hash:', !!window.location.hash);
    console.log('📍 Has code param:', window.location.search.includes('code='));
    
    // Add timeout to prevent infinite waiting
    const timeoutId = setTimeout(() => {
      console.error('⏱️ Callback handler timeout - redirecting to login');
      window.location.href = '/login?error=timeout';
    }, 10000); // 10 second timeout
    
    try {
      // Validate we're on the correct origin
      const storedOrigin = sessionStorage.getItem('oauth-origin') || localStorage.getItem('oauth-origin');
      const storedRedirectUrl = sessionStorage.getItem('oauth-redirect-url') || localStorage.getItem('oauth-redirect-url');
      const currentOrigin = window.location.origin;
      
      console.log('🔍 OAuth Callback - Origin validation:', {
        stored: storedOrigin,
        current: currentOrigin,
        match: storedOrigin === currentOrigin,
        hostname: window.location.hostname,
        port: window.location.port,
        fullUrl: window.location.href,
        storedRedirectUrl: storedRedirectUrl
      });
      
      // Check if we're on the wrong project (24hour project)
      const hostname = window.location.hostname;
      const isWrongProject = hostname.includes('24hour') || 
                            hostname.includes('24-hour') || 
                            (storedOrigin && !currentOrigin.includes(hostname) && hostname !== 'localhost' && hostname !== '127.0.0.1');
      
      // If origin doesn't match OR we're on the wrong project, redirect to the correct origin
      if ((storedOrigin && storedOrigin !== currentOrigin) || isWrongProject) {
        console.warn('⚠️ Origin/project mismatch detected!', {
          expected: storedOrigin,
          actual: currentOrigin,
          isWrongProject: isWrongProject,
          action: 'Redirecting to correct origin...'
        });
        const storedPath = sessionStorage.getItem('oauth-path') || '/signup';
        const correctOrigin = storedOrigin || currentOrigin.replace(/24hour.*|24-hour.*/i, 'localhost:4321');
        // Use replace to prevent back button issues
        window.location.replace(`${correctOrigin}${storedPath}?error=origin_mismatch`);
        return;
      }
      
      // Additional validation: Ensure we're on localhost or the expected domain
      // hostname is already declared above, reuse it
      const isLocalhost = hostname === 'localhost' || hostname === '127.0.0.1';
      const isExpectedDomain = !storedOrigin || storedOrigin.includes(hostname);
      
      if (!isLocalhost && !isExpectedDomain) {
        console.error('❌ Unexpected domain detected!', {
          hostname: hostname,
          storedOrigin: storedOrigin,
          action: 'Redirecting to signup...'
        });
        window.location.replace('/signup?error=invalid_domain');
        return;
      }
      
      // 1) If tokens are in the hash fragment (#access_token=...), set the session directly
      const hash = window.location.hash || '';
      if (hash.includes('access_token')) {
        const params = new URLSearchParams(hash.replace('#', ''));
        const access_token = params.get('access_token');
        const refresh_token = params.get('refresh_token') || params.get('provider_refresh_token');
        const type = params.get('type');

        // Check if this is a password reset (recovery) flow
        if (type === 'recovery' && access_token && refresh_token) {
          console.log('Password reset callback detected, redirecting to reset-password page');
          // Redirect to reset-password page with tokens preserved in hash
          window.location.href = `/reset-password${hash}`;
          return;
        }

        if (access_token && refresh_token) {
          console.log('🔑 Hash tokens found - setting session...');
          try {
            const { data } = await Promise.race([
              supabase.auth.setSession({ access_token, refresh_token }),
              new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 8000))
            ]);

          // Persist to sessionStorage so Header.astro/UI picks up Google email
          if (data?.session?.user) {
            sessionStorage.setItem('simple-auth-session', JSON.stringify({
              user: data.session.user,
              access_token: data.session.access_token,
              timestamp: Date.now()
            }));
            // Notify app
            window.dispatchEvent(new CustomEvent('user-logged-in', { detail: data.session.user }));
          }

            // Clean URL (remove hash) and go to dashboard
            // Use absolute URL to ensure we stay on the same origin
            // Double-check we're on the correct origin before redirecting
            const storedOrigin = sessionStorage.getItem('oauth-origin') || localStorage.getItem('oauth-origin');
            const finalOrigin = storedOrigin && storedOrigin !== window.location.origin ? storedOrigin : window.location.origin;
            const dashboardUrl = `${finalOrigin}/dashboard`;
            console.log('✅ OAuth success, redirecting to:', dashboardUrl, {
              storedOrigin: storedOrigin,
              currentOrigin: window.location.origin,
              finalOrigin: finalOrigin
            });
            window.history.replaceState({}, document.title, '/auth/callback');
            // Clear OAuth origin after successful auth
            sessionStorage.removeItem('oauth-origin');
            sessionStorage.removeItem('oauth-path');
            sessionStorage.removeItem('oauth-redirect-url');
            localStorage.removeItem('oauth-origin');
            localStorage.removeItem('oauth-redirect-url');
            clearTimeout(timeoutId);
            window.location.href = dashboardUrl;
            return;
          } catch (err) {
            console.error('setSession failed:', err);
            clearTimeout(timeoutId);
            window.location.href = `/login?error=${encodeURIComponent(err.message || 'Session setup failed')}`;
            return;
          }
        } else {
          console.warn('⚠️ Missing tokens in hash');
          clearTimeout(timeoutId);
          window.location.href = '/login?error=missing_tokens';
          return;
        }
      } else {
        console.log('ℹ️ No access_token in hash, checking for code param...');
      }

      // 2) If using PKCE (code param), exchange code for a session
      const urlHasCode = window.location.search.includes('code=');
      if (urlHasCode) {
        console.log('🔑 PKCE flow detected - exchanging code for session...');
        // Check if this might be a password reset (check for type=recovery in URL)
        const urlParams = new URLSearchParams(window.location.search);
        const type = urlParams.get('type');
        
        // If it's a recovery type, redirect to reset-password after exchange
        if (type === 'recovery') {
          try {
            const { data, error } = await Promise.race([
              supabase.auth.exchangeCodeForSession(window.location.href),
              new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 8000))
            ]);
            if (error) {
              console.error('Auth callback (PKCE recovery) error:', error);
              clearTimeout(timeoutId);
              window.location.href = '/reset-password?error=invalid_token';
              return;
            } else if (data?.session) {
              // For password reset, redirect to reset-password page
              // The reset-password page will handle the session
              clearTimeout(timeoutId);
              window.location.href = '/reset-password';
              return;
            }
          } catch (err) {
            console.error('PKCE recovery exchange failed:', err);
            clearTimeout(timeoutId);
            window.location.href = '/reset-password?error=timeout';
            return;
          }
        } else {
          // Regular OAuth flow
          console.log('🔄 Exchanging OAuth code for session...');
          console.log('📍 Full callback URL:', window.location.href);
          console.log('📍 Code parameter present:', window.location.search.includes('code='));
          
          // Check if PKCE state exists in storage
          const pkceState = localStorage.getItem('sb-auth-token') || localStorage.getItem('supabase.auth.token');
          console.log('🔑 PKCE state check:', {
            hasStorage: !!pkceState,
            storageKeys: Object.keys(localStorage).filter(k => k.includes('supabase') || k.includes('sb-'))
          });
          
          try {
            // Use the full URL for exchange - Supabase will extract code and verifier
            const exchangeUrl = window.location.href;
            console.log('🔄 Calling exchangeCodeForSession with URL:', exchangeUrl);
            
            const { data, error } = await Promise.race([
              supabase.auth.exchangeCodeForSession(exchangeUrl),
              new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 8000))
            ]);
            if (error) {
              console.error('Auth callback (PKCE) error:', error);
              console.error('Error details:', {
                message: error.message,
                status: error.status,
                name: error.name
              });
              
              // Check if it's a PKCE code verifier error
              if (error.message?.includes('code verifier') || 
                  error.message?.includes('code_verifier') ||
                  error.message?.includes('both auth code and code verifier')) {
                console.error('❌ PKCE code verifier missing! This usually means:');
                console.error('1. The OAuth flow was started on a different origin');
                console.error('2. localStorage was cleared between OAuth start and callback');
                console.error('3. Different Supabase client instances are being used');
                
                // Try to recover by checking if we can get the code from URL and manually handle it
                const urlParams = new URLSearchParams(window.location.search);
                const code = urlParams.get('code');
                
                if (code) {
                  console.log('⚠️ Attempting to recover PKCE state...');
                  // Check localStorage for any Supabase auth state
                  const allKeys = Object.keys(localStorage);
                  const supabaseKeys = allKeys.filter(k => k.includes('supabase') || k.includes('sb-'));
                  console.log('🔑 Supabase keys in localStorage:', supabaseKeys);
                  
                  // If no PKCE state found, redirect to login with helpful message
                  if (supabaseKeys.length === 0) {
                    clearTimeout(timeoutId);
                    const errorMsg = 'PKCE authentication state was lost. This can happen if you were redirected between different projects. Please try signing in again.';
                    window.location.href = `/login?error=${encodeURIComponent(errorMsg)}&type=pkce`;
                    return;
                  }
                }
              }
              
              clearTimeout(timeoutId);
              
              // Check if it's a network/Supabase connection error
              if (error.message?.includes('Failed to fetch') || 
                  error.message?.includes('ERR_NAME_NOT_RESOLVED') ||
                  error.message?.includes('NetworkError')) {
                const errorMsg = 'Cannot connect to authentication server. The Supabase project may be inactive or the URL is incorrect.';
                window.location.href = `/login?error=${encodeURIComponent(errorMsg)}&type=connection`;
              } else {
                // Show error and redirect
                window.location.href = `/login?error=${encodeURIComponent(error.message)}`;
              }
              return;
            } else if (data?.session) {
              console.log('✅ Session obtained successfully');
              clearTimeout(timeoutId);
            // Persist to sessionStorage so Header.astro/UI picks up Google email
            sessionStorage.setItem('simple-auth-session', JSON.stringify({
              user: data.session.user,
              access_token: data.session.access_token,
              timestamp: Date.now()
            }));
            window.dispatchEvent(new CustomEvent('user-logged-in', { detail: data.session.user }));

            // Clean URL (remove query) and redirect
            // Use absolute URL to ensure we stay on the same origin
            // Double-check we're on the correct origin before redirecting
            const storedOrigin = sessionStorage.getItem('oauth-origin') || localStorage.getItem('oauth-origin');
            const finalOrigin = storedOrigin && storedOrigin !== window.location.origin ? storedOrigin : window.location.origin;
            const dashboardUrl = `${finalOrigin}/dashboard`;
            console.log('✅ OAuth success (PKCE), redirecting to:', dashboardUrl, {
              storedOrigin: storedOrigin,
              currentOrigin: window.location.origin,
              finalOrigin: finalOrigin
            });
            window.history.replaceState({}, document.title, '/auth/callback');
            // Clear OAuth origin after successful auth
            sessionStorage.removeItem('oauth-origin');
            sessionStorage.removeItem('oauth-path');
            sessionStorage.removeItem('oauth-redirect-url');
            localStorage.removeItem('oauth-origin');
            localStorage.removeItem('oauth-redirect-url');
            window.location.href = dashboardUrl;
            return;
            }
          } catch (err) {
            console.error('PKCE exchange failed:', err);
            clearTimeout(timeoutId);
            
            // Check if it's a network/Supabase connection error
            if (err.message?.includes('Failed to fetch') || 
                err.message?.includes('ERR_NAME_NOT_RESOLVED') ||
                err.message?.includes('NetworkError') ||
                err.message === 'Timeout') {
              const errorMsg = err.message === 'Timeout' 
                ? 'Authentication timeout - The server took too long to respond. Please check your Supabase configuration.'
                : 'Cannot connect to authentication server. The Supabase project may be inactive or the URL is incorrect.';
              window.location.href = `/login?error=${encodeURIComponent(errorMsg)}&type=connection`;
            } else {
              window.location.href = `/login?error=${encodeURIComponent(err.message || 'Authentication timeout')}`;
            }
            return;
          }
        }
      }

      // 3) Fallback: attempt to read current session
      console.log('🔄 Fallback: Attempting to get existing session...');
      try {
        const { data, error } = await Promise.race([
          supabase.auth.getSession(),
          new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 5000))
        ]);
        if (error) {
          console.error('Auth callback error:', error);
          clearTimeout(timeoutId);
          window.location.href = `/login?error=${encodeURIComponent(error.message)}`;
          return;
        }

      if (data.session?.user) {
        // Persist Google session too
        sessionStorage.setItem('simple-auth-session', JSON.stringify({
          user: data.session.user,
          access_token: data.session.access_token,
          timestamp: Date.now()
        }));
        window.dispatchEvent(new CustomEvent('user-logged-in', { detail: data.session.user }));

        // Redirect to dashboard - use absolute URL
        // Double-check we're on the correct origin before redirecting
        const storedOrigin = sessionStorage.getItem('oauth-origin') || localStorage.getItem('oauth-origin');
        const finalOrigin = storedOrigin && storedOrigin !== window.location.origin ? storedOrigin : window.location.origin;
        const dashboardUrl = `${finalOrigin}/dashboard`;
        console.log('✅ OAuth success (fallback), redirecting to:', dashboardUrl, {
          storedOrigin: storedOrigin,
          currentOrigin: window.location.origin,
          finalOrigin: finalOrigin
        });
        // Clear OAuth origin after successful auth
        sessionStorage.removeItem('oauth-origin');
        sessionStorage.removeItem('oauth-path');
        sessionStorage.removeItem('oauth-redirect-url');
        localStorage.removeItem('oauth-origin');
        localStorage.removeItem('oauth-redirect-url');
        clearTimeout(timeoutId);
        setTimeout(() => {
          window.location.href = dashboardUrl;
        }, 1000);
      } else {
        // No session found - redirect to login
        console.warn('⚠️ No session found in fallback');
        clearTimeout(timeoutId);
        window.location.href = '/login?error=no_session';
      }
      } catch (err) {
        console.error('Fallback session check failed:', err);
        clearTimeout(timeoutId);
        window.location.href = `/login?error=${encodeURIComponent(err.message || 'Session check failed')}`;
        return;
      }
    } catch (err) {
      console.error('Callback error:', err);
      clearTimeout(timeoutId);
      window.location.href = `/login?error=${encodeURIComponent(err.message || 'Authentication failed')}`;
    }
  }

  // Run the callback handler
  handleAuthCallback();

  // Listen for auth state changes
  supabase.auth.onAuthStateChange((event, session) => {
    if (event === 'SIGNED_IN' && session?.user) {
      console.log('User signed in:', session.user);
      
      // Redirect to dashboard - use absolute URL
      // Double-check we're on the correct origin before redirecting
      const storedOrigin = sessionStorage.getItem('oauth-origin') || localStorage.getItem('oauth-origin');
      const finalOrigin = storedOrigin && storedOrigin !== window.location.origin ? storedOrigin : window.location.origin;
      const dashboardUrl = `${finalOrigin}/dashboard`;
      console.log('✅ Auth state changed, redirecting to:', dashboardUrl, {
        storedOrigin: storedOrigin,
        currentOrigin: window.location.origin,
        finalOrigin: finalOrigin
      });
      // Clear OAuth origin after successful auth
      sessionStorage.removeItem('oauth-origin');
      sessionStorage.removeItem('oauth-path');
      sessionStorage.removeItem('oauth-redirect-url');
      localStorage.removeItem('oauth-origin');
      localStorage.removeItem('oauth-redirect-url');
      setTimeout(() => {
        window.location.href = dashboardUrl;
      }, 1000);
    }
  });
</script>
